          }
        },
        {
          "name": "Оформить заказ (checkout)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Order created\", () => {",
