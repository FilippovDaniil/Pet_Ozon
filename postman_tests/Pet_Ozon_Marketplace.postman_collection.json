    {
      "name": "Seller",
      "description": "Кабинет продавца. Требует роль SELLER. Используй `{{sellerToken}}`.",
      "item": [
        {
          "name": "Мои товары",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
