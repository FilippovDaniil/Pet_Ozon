{
  "info": {
    "name": "Pet_Ozon Marketplace",
    "description": "REST API маркетплейса с JWT-аутентификацией.\n\n**Workflow:**\n1. Выполни **Auth / Вход** (client@example.com / pass) — токен сохранится в `clientToken`\n2. Для продавца выполни **Auth / Вход (продавец)** — токен сохранится в `sellerToken`\n3. Для администратора выполни **Auth / Вход (admin)** — токен сохранится в `adminToken`\n4. Все остальные запросы используют заголовок `Authorization: Bearer {{clientToken}}`\n\n**Типичный сценарий клиента:**\nAuth / Вход → Products / Список → Cart / Добавить → Cart / Checkout → Invoice / Оплатить",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8888",
      "type": "string"
    },
    {
      "key": "clientToken",
      "value": "",
      "type": "string",
      "description": "JWT-токен клиента. Заполняется автоматически при выполнении запроса Auth/Вход."
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string",
      "description": "JWT-токен администратора."
    },
    {
      "key": "sellerToken",
      "value": "",
      "type": "string",
      "description": "JWT-токен продавца."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Аутентификация и регистрация. Эндпоинты публичные, токен не нужен.",
      "item": [
        {
          "name": "Вход (клиент)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Token is present\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string').and.not.be.empty;",
                  "    pm.collectionVariables.set('clientToken', json.token);",
                  "});",
                  "pm.test(\"Response has user fields\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys('token', 'userId', 'email', 'role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"pass\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Вход клиента. Токен сохраняется в переменную `clientToken`."
          }
        },
        {
          "name": "Вход (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('adminToken', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"pass\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Вход администратора. Токен сохраняется в `adminToken`."
          }
        },
        {
          "name": "Вход (продавец)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('sellerToken', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller1@example.com\",\n  \"password\": \"pass\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Вход продавца (seller1@example.com). Токен сохраняется в `sellerToken`."
          }
        },
        {
          "name": "Регистрация",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Token returned\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string').and.not.be.empty;",
                  "    pm.collectionVariables.set('clientToken', json.token);",
                  "});",
                  "pm.test(\"Role is CLIENT\", () => pm.expect(pm.response.json().role).to.eql('CLIENT'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"secret123\",\n  \"fullName\": \"Тестовый Пользователь\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Регистрация нового клиента. Возвращает 201 + JWT-токен. Токен сохраняется в `clientToken`."
          }
        }
      ]
    },
    {
      "name": "Profile",
      "description": "Профиль текущего авторизованного пользователя. Требует JWT-токен.",
      "item": [
        {
          "name": "Мой профиль",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Profile has required fields\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys('id', 'email', 'role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{clientToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me"]
            },
            "description": "Возвращает данные текущего пользователя: id, email, fullName, address, role, shopName, balance."
          }
        },
        {
          "name": "Обновить профиль",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"fullName updated\", () => {",
                  "    pm.expect(pm.response.json().fullName).to.eql('Иван Обновлённый');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{clientToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Иван Обновлённый\",\n  \"address\": \"Москва, ул. Обновлённая, 1\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me"]
            },
            "description": "Частичное обновление профиля. Можно передавать любое подмножество полей: fullName, address, shopName."
          }
        }
      ]
    },
    {
      "name": "Products",
      "description": "Каталог товаров. GET-запросы публичные — токен не нужен. Поддерживается пагинация и фильтрация. Ответ — объект Page с полем `content`.",
      "item": [
        {
          "name": "Список товаров",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Response is a Page\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('content');",
                  "    pm.expect(json.content).to.be.an('array');",
                  "    pm.expect(json).to.have.property('totalElements');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                {"key": "page", "value": "0", "description": "Номер страницы (с 0)"},
                {"key": "size", "value": "20", "description": "Размер страницы"},
                {"key": "name", "value": null, "disabled": true, "description": "Фильтр по названию (частичное совпадение)"},
                {"key": "category", "value": null, "disabled": true, "description": "Фильтр по категории"},
                {"key": "minPrice", "value": null, "disabled": true, "description": "Минимальная цена"},
                {"key": "maxPrice", "value": null, "disabled": true, "description": "Максимальная цена"},
                {"key": "sort", "value": null, "disabled": true, "description": "Сортировка, напр. price,asc"}
              ]
            },
            "description": "Возвращает страницу товаров. Поддерживаемые параметры: name, category, minPrice, maxPrice, page, size, sort."
          }
        },
        {
          "name": "Поиск по названию",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Content is array\", () => pm.expect(pm.response.json().content).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?name=ноутбук",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                {"key": "name", "value": "ноутбук"}
              ]
            },
            "description": "Поиск товаров по названию (регистронезависимый)."
          }
        },
        {
          "name": "Фильтр по цене",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?minPrice=1000&maxPrice=50000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                {"key": "minPrice", "value": "1000"},
                {"key": "maxPrice", "value": "50000"}
              ]
            },
            "description": "Фильтрация товаров по диапазону цен."
          }
        },
        {
          "name": "Товар по ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Product has id\", () => pm.expect(pm.response.json()).to.have.property('id'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "1"]
            },
            "description": "Возвращает один товар по ID. Если не найден — 404."
          }
        }
      ]
    },
    {
      "name": "Cart",
