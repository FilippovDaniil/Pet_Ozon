              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"Москва, ул. Примерная, д. 1, кв. 42\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "checkout"]
            },
            "description": "Оформляет заказ. Создаёт Order + Invoice. Корзина очищается. В ответе — данные заказа с invoiceId."
          }
        }
      ]
    },
