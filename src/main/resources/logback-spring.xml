<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback конфигурация с MDC-полями и интеграцией Loki.

  MDC (Mapped Diagnostic Context) — ThreadLocal-хранилище, куда AuditMdcFilter
  кладёт userId, role, requestId перед каждым запросом. Logback подставляет их
  в паттерн через %mdc{key:-default}.

  Профили:
    docker  — консоль + отправка логов в Loki (http://loki:3100)
    !docker — только консоль (локальная разработка)
-->
<configuration>

    <!-- Паттерн включает MDC-поля: userId, role, requestId -->
    <property name="LOG_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [req=%mdc{requestId:-?}] [user=%mdc{userId:-?}@%mdc{role:-system}] %logger{30} - %msg%n"/>

    <!-- ── Консольный вывод — всегда активен ─────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── Профиль "docker": Loki + OpenSearch ──────────────────────────── -->
    <springProfile name="docker">

        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <batchMaxItems>100</batchMaxItems>
            <batchTimeoutMs>5000</batchTimeoutMs>
            <http>
                <url>http://loki:3100/loki/api/v1/push</url>
            </http>
            <format>
                <label>
                    <pattern>app=marketplace,level=%level,role=%mdc{role:-system}</pattern>
                </label>
                <message>
                    <pattern>${LOG_PATTERN}</pattern>
                </message>
                <sortByTime>true</sortByTime>
            </format>
        </appender>

        <!--
          OpenSearch: структурированные логи для Discover.
          Читает OPENSEARCH_HOST / OPENSEARCH_PORT из env (ConfigMap K8s).
          Ежедневный индекс: marketplace-logs-YYYY-MM-DD.
          При недоступности OpenSearch — только пишет ошибку в stderr, не роняет приложение.
        -->
        <appender name="OPENSEARCH" class="com.example.marketplace.logging.OpenSearchLogAppender">
            <host>${OPENSEARCH_HOST:-localhost}</host>
            <port>${OPENSEARCH_PORT:-9200}</port>
            <indexPrefix>marketplace-logs</indexPrefix>
            <batchSize>50</batchSize>
            <flushIntervalSecs>3</flushIntervalSecs>
        </appender>

        <!-- AsyncAppender: не блокируем основной поток при отправке в OpenSearch -->
        <appender name="OPENSEARCH_ASYNC" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="OPENSEARCH"/>
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <includeCallerData>false</includeCallerData>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
            <appender-ref ref="OPENSEARCH_ASYNC"/>
        </root>

        <logger name="com.example.marketplace" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
            <appender-ref ref="OPENSEARCH_ASYNC"/>
        </logger>

    </springProfile>

    <!-- ── Локальная разработка: только консоль ─────────────────────────── -->
    <springProfile name="!docker">

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.example.marketplace" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

    </springProfile>

</configuration>
